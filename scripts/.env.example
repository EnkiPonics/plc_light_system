# .env.example – Vorlage fuer proxmox.env
# Kopieren und anpassen:
#   cp .env.example .env
#
# .env wird NICHT in Git eingecheckt (siehe .gitignore).

PROXMOX_IP=192.168.178.xxx
PROXMOX_PW=dein-passwort
# Fingerprint wird beim ersten plink-Aufruf angezeigt:
# "The server's host key fingerprint is: SHA256:..."
PROXMOX_HOST_KEY=SHA256:xxxx...
